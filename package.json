{
  "name": "ai-knowledge-assistant",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/frontend",
    "packages/backend",
    "packages/shared"
  ],
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "dev": "pnpm run dev:backend & pnpm run dev:frontend",
    "dev:backend": "pnpm --filter @ai-ka/backend dev",
    "dev:frontend": "pnpm --filter @ai-ka/frontend dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "packages/backend/src/**/*.ts": ["vitest run --passWithNoTests"],
    "packages/frontend/src/**/*.ts": ["vitest run --passWithNoTests"]
  }
}
